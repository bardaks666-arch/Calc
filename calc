<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>3D Hub Pro</title>
    <script src="https://unpkg.com/@vkontakte/vk-bridge/dist/browser.min.js"></script>
    <style>
        :root {
            --bg-color: #000000;
            --card-bg: #1c1c1e;
            --text-color: #ffffff;
            --accent-color: #007aff;
            --nav-bg: #121212;
            --input-bg: #2c2c2e;
            --success-color: #32d74b;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            height: 100vh;
            overflow: hidden;
        }

        /* Контейнер для страниц */
        .content {
            flex: 1;
            overflow-y: auto;
            padding: 20px 15px 100px 15px; /* Отступ снизу под навигацию */
        }

        .page { display: none; width: 100%; max-width: 500px; margin: 0 auto; }
        .page.active { display: block; }

        /* Нижняя навигация */
        .tab-bar {
            position: fixed;
            bottom: 0;
            width: 100%;
            height: 70px;
            background: var(--nav-bg);
            border-top: 1px solid #333;
            display: flex;
            justify-content: space-around;
            align-items: center;
            padding-bottom: env(safe-area-inset-bottom);
        }

        .tab-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            color: #8e8e93;
            text-decoration: none;
            font-size: 11px;
            cursor: pointer;
            transition: 0.2s;
        }

        .tab-item.active { color: var(--accent-color); }

        .tab-icon {
            font-size: 24px;
            margin-bottom: 4px;
        }

        /* Элементы интерфейса */
        .card {
            background: var(--card-bg);
            padding: 20px;
            border-radius: 18px;
            margin-bottom: 15px;
        }

        h2 { margin-top: 0; font-size: 22px; text-align: center; }

        label { display: block; font-size: 13px; color: #8e8e93; margin-bottom: 8px; margin-left: 5px; }
        
        input, select {
            width: 100%; height: 46px; background: var(--input-bg);
            border: none; border-radius: 12px; color: white;
            padding: 0 15px; font-size: 16px; box-sizing: border-box; margin-bottom: 15px;
        }

        .row { display: flex; gap: 10px; }
        .row div { flex: 1; }

        button {
            width: 100%; height: 50px; border-radius: 14px; border: none;
            font-weight: 600; font-size: 16px; cursor: pointer; transition: 0.2s;
        }
        button:active { transform: scale(0.98); opacity: 0.8; }
        .btn-blue { background: var(--accent-color); color: white; }

        /* Результаты */
        #result-box {
            background: #2c2c2e; padding: 15px; border-radius: 14px; margin-top: 10px;
            border-left: 4px solid var(--accent-color); display: none;
        }

        /* Заглушки для гайдов */
        .guide-card {
            display: flex; align-items: center; background: var(--card-bg);
            padding: 15px; border-radius: 14px; margin-bottom: 10px; border: 1px solid #333;
        }
        .guide-icon { width: 50px; height: 50px; background: #3a3a3c; border-radius: 10px; margin-right: 15px; display: flex; align-items: center; justify-content: center; font-size: 24px;}
    </style>
</head>
<body>

    <div class="content">
        <div id="page-calc" class="page active">
            <h2>Калькулятор</h2>
            <div class="card">
                <label>Принтер</label>
                <div id="p-info" style="color: var(--accent-color); font-size: 12px; margin-bottom: 10px; text-align: center;"></div>
                
                <label>Филамент</label>
                <select id="f-select" onchange="updateSelectedFilament()"></select>

                <div class="row">
                    <div>
                        <label>Вес (г)</label>
                        <input type="number" id="weight" placeholder="0" inputmode="decimal">
                    </div>
                    <div>
                        <label>Брак (%)</label>
                        <input type="number" id="fail-rate" value="5">
                    </div>
                </div>

                <label>Время печати</label>
                <div class="row">
                    <input type="number" id="hours" placeholder="Ч">
                    <input type="number" id="mins" placeholder="Мин">
                </div>

                <button class="btn-blue" onclick="calculate()">Рассчитать стоимость</button>

                <div id="result-box">
                    <div id="res-total" style="font-size: 24px; font-weight: bold;"></div>
                    <div id="res-details" style="font-size: 13px; color: #aaa; margin-top: 5px;"></div>
                    <div id="res-sale" style="margin-top: 15px; color: var(--success-color); font-weight: bold; border-top: 1px solid #444; padding-top: 10px;"></div>
                </div>
            </div>
        </div>

        <div id="page-guides" class="page">
            <h2>База знаний</h2>
            <div class="guide-card">
                <div class="guide-icon">🛠</div>
                <div>
                    <div style="font-weight: 600;">Калибровка стола</div>
                    <div style="font-size: 12px; color: #8e8e93;">Пошаговое видео для новичков</div>
                </div>
            </div>
            <div class="guide-card">
                <div class="guide-icon">🔥</div>
                <div>
                    <div style="font-weight: 600;">Сушка пластика</div>
                    <div style="font-size: 12px; color: #8e8e93;">Таблица температур и времени</div>
                </div>
            </div>
            <p style="text-align: center; color: #444; font-size: 13px;">Раздел наполняется...</p>
        </div>

        <div id="page-settings" class="page">
            <h2>Настройки</h2>
            <div class="card">
                <label>Ваш тариф электроэнергии (руб/кВт)</label>
                <input type="number" id="elec-cost" step="0.1" value="5.75">
                
                <p style="font-size: 12px; color: #8e8e93;">Здесь в будущем можно будет добавлять свои принтеры и типы пластика.</p>
                <button style="background: #3a3a3c; color: white;" onclick="vkBridge.send('VKWebAppJoinGroup', {group_id: 12345678});">Подписаться на обновления</button>
            </div>
        </div>
    </div>

    <div class="tab-bar">
        <div class="tab-item active" onclick="switchPage('page-calc', this)">
            <div class="tab-icon">🧮</div>
            <div>Расчет</div>
        </div>
        <div class="tab-item" onclick="switchPage('page-guides', this)">
            <div class="tab-icon">📖</div>
            <div>Гайды</div>
        </div>
        <div class="tab-item" onclick="switchPage('page-settings', this)">
            <div class="tab-icon">⚙️</div>
            <div>Опции</div>
        </div>
    </div>

<script>
    vkBridge.send("VKWebAppInit");

    let appData = {
        settings: { electricity: 5.75 },
        printers: [{ name: "AD5X / Reborn 3", power: 650, specs: "220x220" }],
        filaments: [
            { name: "PLA", price: 1000 },
            { name: "PETG", price: 900 },
            { name: "ABS", price: 1100 }
        ]
    };

    function switchPage(pageId, el) {
        document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.tab-item').forEach(t => t.classList.remove('active'));
        document.getElementById(pageId).classList.add('active');
        el.classList.add('active');
    }

    function init() {
        const sel = document.getElementById('f-select');
        appData.filaments.forEach((f, i) => {
            sel.innerHTML += `<option value="${i}">${f.name} (${f.price} руб.)</option>`;
        });
        document.getElementById('p-info').innerText = appData.printers[0].name + " | " + appData.printers[0].power + "W";
    }

    function calculate() {
        const w = parseFloat(document.getElementById('weight').value) || 0;
        const h = parseFloat(document.getElementById('hours').value) || 0;
        const m = parseFloat(document.getElementById('mins').value) || 0;
        const fail = parseFloat(document.getElementById('fail-rate').value) || 0;
        const elec = parseFloat(document.getElementById('elec-cost').value) || 5.75;

        const filament = appData.filaments[document.getElementById('f-select').value];
        const printer = appData.printers[0];

        // Логика расчета
        const timeDec = h + (m/60);
        const weightWithFail = w * (1 + fail/100);
        const costFilament = (weightWithFail / 1000) * filament.price;
        const costElec = (printer.power * timeDec / 1000) * elec;
        
        const total = costFilament + costElec;
        const sale = total * 3;

        const box = document.getElementById('result-box');
        box.style.display = 'block';
        document.getElementById('res-total').innerText = total.toFixed(2) + " руб.";
        document.getElementById('res-details').innerHTML = `Пластик: ${costFilament.toFixed(2)} руб. <br> Энергия: ${costElec.toFixed(2)} руб.`;
        document.getElementById('res-sale').innerText = "Цена продажи (x3): " + sale.toFixed(0) + " руб.";
        
        box.scrollIntoView({behavior: 'smooth'});
    }

    init();
</script>
</body>
</html>
